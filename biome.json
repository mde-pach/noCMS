{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dist",
      "!.vite",
      "!node_modules",
      "!.claude",
      "!**/*.gen.ts",
      "!**/vendor",
      "!design_handoff_nocms_editor",
      "!templates/starter/public/feed.json",
      "!templates/starter/public/search.json",
      "!templates/starter/public/sitemap.xml",
      "!templates/starter/public/manifest.json",
      "!templates/starter/public/i18n"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 88
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "useSemanticElements": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    },
    "jsxRuntime": "reactClassic"
  },
  "assist": {
    "enabled": true
  }
}
